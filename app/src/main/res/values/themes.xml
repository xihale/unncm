<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.unNCM" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary_container</item>

        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/brand_on_secondary</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/brand_on_secondary_container</item>

        <item name="colorSurface">@color/brand_surface</item>
        <item name="colorOnSurface">@color/brand_on_surface</item>
        <item name="colorSurfaceVariant">@color/brand_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/brand_on_surface_variant</item>
        <item name="colorOutline">@color/brand_outline</item>
        <item name="colorOutlineVariant">@color/brand_outline_variant</item>

        <item name="colorError">@color/brand_error</item>
        <item name="colorOnError">@color/brand_on_error</item>
        <item name="colorErrorContainer">@color/brand_error_container</item>
        <item name="colorOnErrorContainer">@color/brand_on_error_container</item>

        <item name="android:windowBackground">@drawable/bg_screen_tech</item>

        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.unNCM.Sharp</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.unNCM.Sharp</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.unNCM.Sharp</item>

        <item name="materialButtonStyle">@style/Widget.unNCM.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.unNCM.Button.Outlined</item>
    </style>

    <style name="Theme.unNCM" parent="Base.Theme.unNCM" />

    <style name="ShapeAppearance.unNCM.Sharp" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">0dp</item>
    </style>

    <style name="Widget.unNCM.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.unNCM.Sharp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:minHeight">46dp</item>
        <item name="backgroundTint">?attr/colorPrimaryContainer</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.unNCM.Button.Primary" parent="Widget.Material3.Button">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.unNCM.Sharp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:minHeight">48dp</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.unNCM.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.unNCM.Sharp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:minHeight">46dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>
